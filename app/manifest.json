  "shortcuts": [
    {
      "name": "New Project",
      "short_name": "New",
      "description": "Start a new CAD project",
      "url": "/app/?action=new",
      "icons": [
        {
          "src": "/app/icons/shortcut-new-192.png",
          "sizes": "192x192",
          "type": "image/png"
        }
      ]
    },
    {
      "name": "Open Project",
      "short_name": "Open",
      "description": "Open an existing project",
      "url": "/app/?action=open",
      "icons": [
        {
          "src": "/app/icons/shortcut-open-192.png",
          "sizes": "192x192",
          "type": "image/png"
        }
      ]
    },
    {
      "name": "Import STEP",
      "short_name": "Import",
      "description": "Import a STEP file",
      "url": "/app/?action=import",
      "icons": [
        {
          "src": "/app/icons/shortcut-import-192.png",
          "sizes": "192x192",
          "type": "image/png"
        }
      ]
    }
  ],
  "share_target": {
    "action": "/app/",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url",
      "files": [
        {
          "name": "file",
          "accept": [
            "model/step",
            "model/x.step",
            "model/stp",
            "model/x.stp",
            "model/stl",
            "model/x.stl",
            "model/obj",
            "model/x.obj",
            "model/gltf+json",
            "model/gltf-binary",
            "application/json"
          ]
        }
      ]
    }
  },
  "file_handlers": [
    {
      "action": "/app/",
      "accept": {
        "model/step": [".step", ".STEP"],
        "model/x.step": [".stp", ".STP"]
      },
      "icons": [
        {
          "src": "/app/icons/icon-192.png",
          "sizes": "192x192"
        }
      ]
    },
    {
      "action": "/app/",
      "accept": {
        "model/stl": [".stl", ".STL"],
        "model/obj": [".obj", ".OBJ"],
        "model/gltf-binary": [".glb", ".GLB"]
      },
      "icons": [
        {
          "src": "/app/icons/icon-192.png",
          "sizes": "192x192"
        }
      ]
    }
  ],
  "launch_handler": {
    "client_mode": ["navigate-new", "auto"]
  },
  "protocol_handlers": [
    {
      "protocol": "web+cyclecad",
      "url": "/app/?project=%s"
    }
  ],
  "prefer_related_applications": false,
  "related_applications": [],
  "screenshots_details": [
    {
      "form_factor": "narrow",
      "src": "/app/icons/screenshot-540.png",
      "type": "image/png"
    },
    {
      "form_factor": "wide",
      "src": "/app/icons/screenshot-1280.png",
      "type": "image/png"
    }
  ]
}
