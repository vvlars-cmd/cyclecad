{
  "$schema": "../../docs/pentacad/machine-config-schema.json",
  "_note": "Pentamachine V2-50. Real board revision key (used by Rockhopper to pick the INI): v2revR. Confirmed from https://github.com/PocketNC/Settings/tree/master/versions/v2revR and the Kinetic Control v5.8.4 disk image.",
  "machineId": "v2-50",
  "vendor": "Penta Machine Company",
  "productUrl": "https://www.pentamachine.com/v2-50",
  "family": "V2",
  "variant": "50",
  "displayName": "Pentamachine V2-50",
  "type": "5-axis-AB-table",
  "description": "Larger-envelope 5-axis desktop CNC with A-tilt + B-rotary table. 40,000 RPM ER20 spindle. Replaces the fabricated CHB/CHK sub-variants.",

  "linux_cnc": {
    "boardRevision": "v2revR",
    "iniTemplatePath": "/opt/pocketnc/Settings/versions/v2revR/PocketNC.ini",
    "calibrationOverlayPath": "/var/opt/pocketnc/CalibrationOverlay.inc",
    "kinematicsFeature": "five_axis_kinematics",
    "kinematicsModule": "pocketnckins",
    "_note": "Runtime INI is generated by /opt/pocketnc/Settings/generateINI.py, which merges the versioned template with CalibrationOverlay.inc + any enabled features from /opt/pocketnc/Settings/features/."
  },

  "linear": {
    "x": { "min": -5.0, "max": 5.0, "unit": "inch", "_confirmed": false, "_source": "V2-50 marketing; confirm against active INI via Rockhopper `get ini_filename` + parse" },
    "y": { "min": -3.5, "max": 3.5, "unit": "inch", "_confirmed": false },
    "z": { "min": -2.5, "max": 2.5, "unit": "inch", "_confirmed": false }
  },

  "rotary": {
    "a": { "min": -35, "max": 135, "unit": "deg", "axis": "X", "_confirmed": false },
    "b": { "min": -360, "max": 360, "unit": "deg", "axis": "Z", "continuous": true, "_confirmed": false }
  },

  "pivots": {
    "a_to_table":   { "x": 0, "y": 0, "z": 0.5 },
    "b_to_a":       { "x": 0, "y": 0, "z": 0 },
    "spindle_to_a": { "x": 0, "y": 0, "z": 2.5 }
  },

  "home":             { "x": 0, "y": 0, "z": 0, "a": 0, "b": 0 },
  "tool_length_zero": 2.5,

  "spindle": {
    "type": "ER20",
    "min_rpm": 2000,
    "max_rpm": 40000,
    "_confirmed": true,
    "_source": "Matt sample .ngc files show S40000 commanded"
  },

  "max_feed": {
    "rapid_linear": { "value": 5000, "unit": "inch/min", "_confirmed": false },
    "rapid_rotary": { "value": 5000, "unit": "deg/min",  "_confirmed": false },
    "cut":          { "value": 60,   "unit": "inch/min", "_confirmed": false }
  },

  "coolant": {
    "mist":  { "m_code": 7, "supported": true },
    "flood": { "m_code": 8, "supported": true },
    "off":   { "m_code": 9 }
  },

  "controller": {
    "platform": "LinuxCNC (pocketnc fork) on BeagleBone Black",
    "os": "Debian Buster",
    "kineticControlVersion": "5.8.4 (2025-04-01)",
    "sourceRepos": {
      "application": "https://github.com/PocketNC/emcapplication",
      "rockhopper":  "https://github.com/PocketNC/Rockhopper",
      "settings":    "https://github.com/PocketNC/Settings"
    },
    "_confirmed": true
  },

  "viewer": {
    "glbPath": "/opt/penta-ui-builds/gltf/v2-50.glb",
    "glbMD5":  "fbbdcb1b84602e7e836b1cd17afde9b3",
    "_note": "GLB ships on every Pentamachine. Pentacad viewport can bundle or fetch."
  },

  "rockhopper": {
    "wsUrl": "ws://<machine>:8000/websocket/",
    "subprotocol": "linuxcnc",
    "defaultUser": "default",
    "defaultPassword": "default",
    "_note": "Change default credentials in production. CORS origin regex currently restricts to pocketnc.com subdomains — see docs/pentacad/rockhopper-notes.md."
  },

  "post": {
    "dialect": "Pentamachine V2",
    "units": "inch",
    "planeCode": "G17",
    "distanceCode": "G90",
    "wcsDefault": "G54",
    "feedModeDefault": "G94",
    "feedModeFor5Axis": "G93",
    "cutterComp": "G40",
    "decimalPlacesLinear": 4,
    "decimalPlacesRotary": 3
  },

  "tools": [
    { "id": 1, "description": "1/4\" flat endmill 2FL carbide", "type": "flat", "dia_in": 0.25,  "dia_mm": 6.35,  "flutes": 2, "max_rpm": 18000 },
    { "id": 2, "description": "1/8\" flat endmill 2FL",         "type": "flat", "dia_in": 0.125, "dia_mm": 3.175, "flutes": 2, "max_rpm": 24000 },
    { "id": 3, "description": "1/8\" ballnose 2FL",             "type": "ball", "dia_in": 0.125, "dia_mm": 3.175, "flutes": 2, "max_rpm": 24000 },
    { "id": 4, "description": "90° V-bit engraver",             "type": "vbit", "dia_in": 0.125, "dia_mm": 3.175, "flutes": 1, "max_rpm": 18000, "angle_deg": 90 },
    { "id": 5, "description": "3 mm HSS-Co drill",              "type": "drill","dia_in": 0.118, "dia_mm": 3.0,   "flutes": 2, "max_rpm": 3500 }
  ],

  "features": {
    "_note": "PocketNC Settings/features/ directory contents. Each feature has its own detect script that decides whether to enable it on this machine.",
    "available": [
      "configure_cape_universal",
      "five_axis_kinematics",
      "high_speed_spindle",
      "interlock",
      "load_pocketnc_driver",
      "m6_tool_probe",
      "rotated_work_offsets",
      "rt_preempt_prubin",
      "run_time_clock",
      "spindle_logging",
      "usb_drive",
      "wrapped_rotary",
      "xenomai_prubin"
    ]
  },

  "singularity_notes": [
    "A-axis near 0° causes B-axis gimbal behaviour; post should favour small non-zero A when reachable.",
    "Wrapped_rotary feature allows B to exceed ±360° — coordinate with the wrapped_rotary INI override."
  ],

  "safety": {
    "estop": { "hardware": true, "m_code": 0 },
    "probing": { "supported": true, "g_code": "G38.2", "default_feed_in_per_min": 2 },
    "wcs": ["G54","G55","G56","G57","G58","G59"]
  }
}
